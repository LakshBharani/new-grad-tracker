# Copy to .env.local for local dev, and set the same keys in Vercel
# (Project → Settings → Environment Variables) for production.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI.
# Use the **Transaction pooler** URL (port 6543) for Next.js serverless routes.
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Required in every environment. Generate with: openssl rand -base64 32
# Missing/empty secret in production makes login fail.
NEXTAUTH_SECRET=

# Optional. The app sets `trustHost: true`, so this is usually NOT needed on Vercel.
# If you do set it in production, use your real domain — NEVER localhost.
# NEXTAUTH_URL=https://your-app.vercel.app

# Optional registration invite code (defaults to "friends2024" if unset).
# INVITE_CODE=

# ── Supabase (public) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
